---
type Props = {
  title: string
}

const { title } = Astro.props
const { preview } = Astro.locals
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    {
      preview && (
        <p>
          Preview mode — <a href="/api/preview/exit">exit</a>
        </p>
      )
    }
    <main>
      <slot />
    </main>
  </body>
</html>
